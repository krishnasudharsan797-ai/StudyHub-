# StudyHub Environment Variables
# Copy this file to .env.local and fill in values if needed

# App Settings
VITE_APP_NAME=StudyHub
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# API (for future backend integration)
# VITE_API_URL=http://localhost:3000/api

# Analytics (for future use)
# VITE_GA_ID=

# Feature Flags
VITE_ENABLE_ADMIN=true
VITE_ENABLE_SEARCH=true
VITE_ENABLE_SAVE=true
